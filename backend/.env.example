# Copy this file to backend/.env and fill in your local values.

# Local HuggingFace embedding model root directory.
# The project will resolve BAAI/bge-small-zh-v1.5 as:
# <HF_MODEL_PATH>/BAAI/bge-small-zh-v1.5
HF_MODEL_PATH=F:/models

# Force the embedding model onto CUDA when a CUDA-enabled PyTorch build is installed.
EMBEDDING_DEVICE=cuda
HF_ENDPOINT=https://hf-mirror.com

# Cloud embedding / generation providers
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ALIYUN_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
